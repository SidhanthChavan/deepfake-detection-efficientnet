## 7. XceptionNet Comparison

```python
#@title Train XceptionNet (3 epochs) and Compare

def get_xception(num_classes=2):
    model = timm.create_model('xception', pretrained=True)
    in_features = model.fc.in_features
    model.fc = nn.Linear(in_features, num_classes)
    return model

xception = get_xception().to(device)
optimizer_x = torch.optim.Adam(xception.parameters(), lr=1e-4)
best_acc_x = 0
MODEL_PATH_X = os.path.join(DRIVE_PATH, 'xception_best.pt')
history_x = {'train_loss': [], 'train_acc': [], 'val_loss': [], 'val_acc': []}

for epoch in range(3):
    train_loss, train_acc = train_one_epoch(xception, train_loader, optimizer_x, criterion)
    val_loss, val_acc, _, _, _ = validate(xception, val_loader, criterion)
    history_x['train_loss'].append(train_loss)
    history_x['train_acc'].append(train_acc)
    history_x['val_loss'].append(val_loss)
    history_x['val_acc'].append(val_acc)
    print(f"Xception Epoch {epoch+1}/3 - Train loss: {train_loss:.4f}, acc: {train_acc:.4f} | Val loss: {val_loss:.4f}, acc: {val_acc:.4f}")
    if val_acc > best_acc_x:
        best_acc_x = val_acc
        torch.save(xception.state_dict(), MODEL_PATH_X)
        print(f"Saved best Xception model to {MODEL_PATH_X}")

# Evaluate XceptionNet
xception.load_state_dict(torch.load(MODEL_PATH_X, map_location=device))
val_loss_x, val_acc_x, y_true_x, y_pred_x, y_prob_x = validate(xception, val_loader, criterion)
f1_x = f1_score(y_true_x, y_pred_x)
roc_auc_x = roc_auc_score(y_true_x, y_prob_x)
cm_x = confusion_matrix(y_true_x, y_pred_x)

# Comparison DataFrame
results_df = pd.DataFrame({
    'Model': ['EfficientNet-B4', 'XceptionNet'],
    'Accuracy': [val_acc, val_acc_x],
    'F1': [f1, f1_x],
    'ROC-AUC': [roc_auc, roc_auc_x]
})
print(results_df)
```

