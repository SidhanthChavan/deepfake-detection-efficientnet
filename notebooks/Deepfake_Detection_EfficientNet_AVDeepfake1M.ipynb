## 6. Grad-CAM Visualization

```python
#@title Grad-CAM on 5 Random Test Frames

from pytorch_grad_cam.utils.image import deprocess_image

def gradcam_on_frames(model, loader, n_examples=5, class_idx=1):
    model.eval()
    # For EfficientNet, use last conv layer name
    target_layers = [model.blocks[-1][-1].conv_pwl]
    cam = GradCAM(model=model, target_layers=target_layers, use_cuda=torch.cuda.is_available())
    count = 0
    for images, labels in loader:
        images = images.to(device)
        for i in range(images.size(0)):
            if count >= n_examples:
                return
            input_tensor = images[i].unsqueeze(0)
            grayscale_cam = cam(input_tensor=input_tensor, targets=[ClassifierOutputTarget(class_idx)])
            grayscale_cam = grayscale_cam[0, :]
            rgb_img = input_tensor[0].cpu().permute(1,2,0).numpy()
            rgb_img = std * rgb_img + mean # unnormalize
            rgb_img = np.clip(rgb_img, 0, 1)
            vis_img = show_cam_on_image(rgb_img, grayscale_cam, use_rgb=True)
            plt.figure(figsize=(7,3))
            plt.subplot(1,2,1)
            plt.title("Original")
            plt.imshow(rgb_img)
            plt.axis('off')
            plt.subplot(1,2,2)
            plt.title("GradCAM")
            plt.imshow(vis_img)
            plt.axis('off')
            plt.tight_layout()
            plt.savefig(f'/content/gradcam_example_{count}.png')
            plt.show()
            count += 1

gradcam_on_frames(model, val_loader, n_examples=5)
```

