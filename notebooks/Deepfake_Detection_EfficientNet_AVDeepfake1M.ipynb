## 3. Custom Dataset

```python
#@title PyTorch Dataset for Frames

class DeepfakeFramesDataset(Dataset):
    def __init__(self, frame_dir, label, transform=None):
        self.frame_paths = sorted(glob.glob(os.path.join(frame_dir, '*.jpg')))
        self.label = label  # 0 = real, 1 = fake
        self.transform = transform

    def __len__(self):
        return len(self.frame_paths)

    def __getitem__(self, idx):
        img_path = self.frame_paths[idx]
        try:
            image = Image.open(img_path).convert('RGB')
        except Exception as e:
            print(f"Error loading {img_path}: {e}")
            image = Image.new('RGB', (224,224), (0,0,0))
        if self.transform:
            image = self.transform(image)
        return image, self.label

# Transforms (with normalization as per EfficientNet)
mean=[0.485, 0.456, 0.406]
std=[0.229, 0.224, 0.225]

train_transform = transforms.Compose([
    transforms.RandomHorizontalFlip(),
    transforms.RandomRotation(10),
    transforms.ToTensor(),
    transforms.Normalize(mean, std)
])
val_transform = transforms.Compose([
    transforms.ToTensor(),
    transforms.Normalize(mean, std)
])

# Create datasets (80/20 split, shuffle)
real_frame_paths = glob.glob(os.path.join(FRAME_ROOT, 'real', '*.jpg'))
fake_frame_paths = glob.glob(os.path.join(FRAME_ROOT, 'fake', '*.jpg'))

random.seed(42)
random.shuffle(real_frame_paths)
random.shuffle(fake_frame_paths)

split_real = int(0.8 * len(real_frame_paths))
split_fake = int(0.8 * len(fake_frame_paths))

train_real = real_frame_paths[:split_real]
train_fake = fake_frame_paths[:split_fake]
val_real = real_frame_paths[split_real:]
val_fake = fake_frame_paths[split_fake:]

train_dataset = DeepfakeFramesDataset(FRAME_ROOT+'/real', 0, transform=train_transform)
train_dataset.frame_paths = train_real
train_dataset_fake = DeepfakeFramesDataset(FRAME_ROOT+'/fake', 1, transform=train_transform)
train_dataset_fake.frame_paths = train_fake

val_dataset = DeepfakeFramesDataset(FRAME_ROOT+'/real', 0, transform=val_transform)
val_dataset.frame_paths = val_real
val_dataset_fake = DeepfakeFramesDataset(FRAME_ROOT+'/fake', 1, transform=val_transform)
val_dataset_fake.frame_paths = val_fake

# Combine datasets
from torch.utils.data import ConcatDataset

train_full = ConcatDataset([train_dataset, train_dataset_fake])
val_full = ConcatDataset([val_dataset, val_dataset_fake])

train_loader = DataLoader(train_full, batch_size=16, shuffle=True, num_workers=2, pin_memory=True)
val_loader = DataLoader(val_full, batch_size=16, shuffle=False, num_workers=2, pin_memory=True)
print(f"Train size: {len(train_full)}, Val size: {len(val_full)}")
```

